<Window x:Class="ProtocolTestBench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ProtocolTestBench" Height="760" Width="1180"
        MinHeight="640" MinWidth="980"
        FontFamily="Microsoft YaHei UI"
        Background="#EEF3F8"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部应用栏：左侧是应用名，中间是协议页菜单，右侧是全局状态提示。 -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ProtocolTestBench"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="Socket / CFX（AMQP） / MQTT / STOMP 调试台"
                               Style="{StaticResource HintTextStyle}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Menu Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <MenuItem x:Name="SocketMenuItem"
                              Header="Socket"
                              IsCheckable="True"
                              IsChecked="True"
                              Click="SocketMenuItem_Click" />
                    <MenuItem x:Name="CfxMenuItem"
                              Header="CFX / AMQP"
                              IsCheckable="True"
                              Click="CfxMenuItem_Click" />
                    <MenuItem x:Name="MqttMenuItem"
                              Header="MQTT"
                              IsCheckable="True"
                              Click="MqttMenuItem_Click" />
                    <MenuItem x:Name="StompMenuItem"
                              Header="STOMP"
                              IsCheckable="True"
                              Click="StompMenuItem_Click" />
                </Menu>

                <Button Grid.Column="3"
                        MinWidth="108"
                        Content="JSON 美化"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="JsonFormatterButton_Click" />
            </Grid>
        </Border>

        <!-- Socket 页面：上方连接参数，下方左右布局，左侧日志、右侧发送。 -->
        <Grid x:Name="SocketView" Grid.Row="1" Margin="18" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Socket 连接参数区：模式、地址、端口和启动/清空操作。 -->
            <Border Grid.Row="0" Style="{StaticResource ToolPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="模式" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="ModeComboBox"
                                  SelectedIndex="0"
                                  SelectionChanged="SocketModeComboBox_SelectionChanged"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem Content="服务端" Tag="Server" />
                            <ComboBoxItem Content="客户端" Tag="Client" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock x:Name="RemoteHostLabel"
                                   Text="服务端地址"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="RemoteHostTextBox" Text="127.0.0.1" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock x:Name="PortLabel"
                                   Text="端口"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="PortTextBox" Text="9000" />
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <Button x:Name="StartButton"
                                Content="启动"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SocketStartButton_Click" />
                        <Button x:Name="ClearButton"
                                Content="清空日志"
                                Margin="10,0,0,0"
                                Click="SocketClearLogButton_Click" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Margin="0,14,0,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,9">
                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="未启动" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <!-- Socket 日志区：显示连接、接收、发送和异常记录。 -->
                <Border Grid.Column="0" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                            <TextBlock Text="收发记录"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,5">
                                <TextBlock x:Name="ConnectionCountTextBlock"
                                           Foreground="#1D4ED8"
                                           FontWeight="SemiBold"
                                           Text="连接数：0" />
                            </Border>
                        </DockPanel>

                        <TextBox x:Name="LogTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Grid>
                </Border>

                <!-- Socket 发送区：服务端模式可选择目标客户端，客户端模式直接发给服务端。 -->
                <Border Grid.Column="2" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                            <TextBlock Text="发送内容"
                                       Style="{StaticResource PanelTitleStyle}" />
                        </DockPanel>

                        <StackPanel x:Name="ServerTargetPanel"
                                    Grid.Row="1"
                                    Margin="0,0,0,10"
                                    Visibility="Collapsed">
                            <TextBlock Text="发送目标" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <ToggleButton x:Name="TargetDropDownButton"
                                              MinWidth="240"
                                              HorizontalContentAlignment="Left"
                                              Content="所有客户端" />
                                <Popup x:Name="TargetPopup"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=TargetDropDownButton}"
                                       IsOpen="{Binding IsChecked, ElementName=TargetDropDownButton, Mode=TwoWay}"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Width="{Binding ActualWidth, ElementName=TargetDropDownButton}"
                                            MinWidth="280"
                                            MaxHeight="260"
                                            Margin="0,4,0,0"
                                            Padding="10"
                                            Background="White"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Button x:Name="SelectAllTargetsButton"
                                                        MinWidth="70"
                                                        Content="全选"
                                                        Click="SocketSelectAllTargetsButton_Click" />
                                                <Button x:Name="ClearTargetsButton"
                                                        MinWidth="70"
                                                        Margin="8,0,0,0"
                                                        Content="清空"
                                                        Click="SocketClearTargetsButton_Click" />
                                            </StackPanel>
                                            <TextBlock x:Name="NoClientsTextBlock"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="暂无已连接客户端" />
                                            <ListBox x:Name="ClientTargetsListBox"
                                                     BorderThickness="0"
                                                     MaxHeight="180"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding DisplayName}"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Checked="SocketClientTargetCheckBox_Changed"
                                                                  Unchecked="SocketClientTargetCheckBox_Changed" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox x:Name="MessageTextBox"
                                     Grid.Row="0"
                                     Height="220"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     KeyDown="SocketMessageTextBox_KeyDown" />
                            <Button x:Name="SendButton"
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    MinWidth="110"
                                    HorizontalAlignment="Right"
                                    Content="发送"
                                    IsEnabled="False"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SocketSendButton_Click" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- CFX 页面：上方端点参数，下方左右布局，左侧日志、右侧发布/点对点操作。 -->
        <Grid x:Name="CfxView"
              Grid.Row="1"
              Margin="18"
              Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- CFX/AMQP 参数区：配置 endpoint handle、broker、vhost、发布/订阅和点对点本端 URI。 -->
            <Border Grid.Row="0" Style="{StaticResource ToolPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="1.45*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="CFX Handle" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxHandleTextBox" Text="GKG.ProtocolTestBench.TestClient" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Broker URI" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxBrokerTextBox" Text="amqp://127.0.0.1:5672" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="VirtualHost" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxVirtualHostTextBox"
                                     ToolTip="RabbitMQ 可使用 vhost:MYVHOST；默认留空。" />
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button x:Name="CfxOpenButton"
                                    Content="打开"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CfxOpenButton_Click" />
                            <Button x:Name="CfxClearButton"
                                    Content="清空日志"
                                    Margin="10,0,0,0"
                                    Click="CfxClearLogButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="发布地址" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxPublishAddressTextBox" Text="/exchange/cfx.demo/printer01.inbox" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="订阅地址" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxSubscribeAddressTextBox" Text="/exchange/cfx.demo/events" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="本端请求 URI" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="CfxRequestUriTextBox" Width="263" HorizontalAlignment="Left"
                                     ToolTip="点对点 Request/Response 接收请求时使用完整 URI，例如 amqp://0.0.0.0:5673；留空则不主动指定监听地址。" />
                        </StackPanel>

                        <Border Grid.Column="6"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,9"
                                VerticalAlignment="Bottom">
                            <TextBlock x:Name="CfxStatusTextBlock"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="未打开：填写 AMQP 1.0 broker、发布地址和订阅地址后打开端点" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" MinWidth="410" />
                </Grid.ColumnDefinitions>

                <!-- CFX/AMQP 日志区：显示 SDK 连接事件、收到的 Envelope、请求和响应。 -->
                <Border Grid.Column="0" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                            <TextBlock Text="CFX / AMQP 收发记录"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Background="#ECFDF5"
                                    BorderBrush="#A7F3D0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,5">
                                <TextBlock x:Name="CfxConnectionTextBlock"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="SemiBold"
                                           Text="端点：未打开" />
                            </Border>
                        </DockPanel>

                        <TextBox x:Name="CfxLogTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Grid>
                </Border>

                <!-- CFX 操作区：发布/订阅消息发送和点对点请求分成标签页，避免纵向堆叠。 -->
                <Border Grid.Column="2" Style="{StaticResource ToolPanelStyle}">
                    <TabControl HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                        <TabItem Header="发布消息">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                                    <TextBlock Text="发送 CFX Envelope JSON"
                                               Style="{StaticResource PanelTitleStyle}" />
                                    <Button x:Name="CfxSampleButton"
                                            DockPanel.Dock="Right"
                                            MinWidth="96"
                                            Content="载入示例"
                                            Click="CfxSampleButton_Click" />
                                </DockPanel>

                                <TextBox x:Name="CfxMessageTextBox"
                                         Grid.Row="1"
                                         MinHeight="260"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         Style="{StaticResource ConsoleTextBoxStyle}"
                                         KeyDown="CfxMessageTextBox_KeyDown" />
                                <Button x:Name="CfxSendButton"
                                        Grid.Row="2"
                                        Margin="0,12,0,0"
                                        MinWidth="110"
                                        HorizontalAlignment="Center"
                                        Content="发送"
                                        IsEnabled="False"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="CfxSendButton_Click" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="点对点 Request/Response">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                                    <TextBlock Text="点对点 Request / Response"
                                               Style="{StaticResource PanelTitleStyle}" />
                                    <Button x:Name="CfxRequestSampleButton"
                                            DockPanel.Dock="Right"
                                            MinWidth="112"
                                            Content="载入示例"
                                            Click="CfxRequestSampleButton_Click" />
                                </DockPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="目标请求 URI" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox x:Name="CfxTargetRequestUriTextBox"
                                             Text="amqp://127.0.0.1:5673"
                                             ToolTip="对方 Endpoint 的 Request URI，必须是完整 URI。" />
                                </StackPanel>

                                <Grid Grid.Row="2" MinHeight="260">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="请求 Envelope JSON" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="CfxRequestMessageTextBox"
                                                 Grid.Row="1"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Style="{StaticResource ConsoleTextBoxStyle}" />
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="自动响应 Envelope JSON" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox x:Name="CfxAutoResponseTextBox"
                                                 Grid.Row="1"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Style="{StaticResource ConsoleTextBoxStyle}"
                                                 ToolTip="收到点对点请求时返回这里的 Envelope JSON。" />
                                    </Grid>
                                </Grid>

                                <Button x:Name="CfxExecuteRequestButton"
                                        Grid.Row="3"
                                        Margin="0,12,0,0"
                                        MinWidth="110"
                                        HorizontalAlignment="Center"
                                        Content="执行请求"
                                        IsEnabled="False"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="CfxExecuteRequestButton_Click" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- MQTT 页面：上方 broker 和订阅参数，下方左右布局，左侧日志、右侧发布。 -->
        <Grid x:Name="MqttView"
              Grid.Row="1"
              Margin="18"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- MQTT 参数区：配置 broker、客户端标识、认证和订阅主题。 -->
            <Border Grid.Row="0" Style="{StaticResource ToolPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Broker 地址" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttBrokerHostTextBox" Text="127.0.0.1" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="端口" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttBrokerPortTextBox" Text="1883" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="ClientId" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttClientIdTextBox" Text="ProtocolTestBench.MqttClient" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Text="用户名" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttUserNameTextBox" Text="guest"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,12,0">
                            <TextBlock Text="密码" Style="{StaticResource FieldLabelStyle}" />
                            <PasswordBox x:Name="MqttPasswordBox" Password="guest"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <CheckBox x:Name="MqttCleanSessionCheckBox"
                                      Margin="0,0,10,10"
                                      VerticalAlignment="Center"
                                      IsChecked="True"
                                      Content="Clean Session" />
                            <Button x:Name="MqttConnectButton"
                                    Content="连接"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="MqttConnectButton_Click" />
                            <Button x:Name="MqttClearButton"
                                    Content="清空日志"
                                    Margin="10,0,0,0"
                                    Click="MqttClearLogButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1.3*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="订阅主题" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttSubscribeTopicTextBox" Text="gkg/demo/inbox" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="订阅 QoS" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="MqttSubscribeQoSComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="QoS 0" Tag="0" />
                                <ComboBoxItem Content="QoS 1" Tag="1" />
                                <ComboBoxItem Content="QoS 2" Tag="2" />
                            </ComboBox>
                        </StackPanel>

                        <Button x:Name="MqttSubscribeButton"
                                Grid.Column="2"
                                MinWidth="86"
                                Margin="0,22,10,0"
                                Content="订阅"
                                Click="MqttSubscribeButton_Click" />

                        <Button x:Name="MqttUnsubscribeButton"
                                Grid.Column="3"
                                MinWidth="86"
                                Margin="0,22,0,0"
                                Content="取消订阅"
                                Click="MqttUnsubscribeButton_Click" />

                        <Border Grid.Column="5"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,9"
                                VerticalAlignment="Bottom">
                            <TextBlock x:Name="MqttStatusTextBlock"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="未连接：填写 broker、ClientId 和主题后连接" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" MinWidth="410" />
                </Grid.ColumnDefinitions>

                <!-- MQTT 日志区：显示连接事件、订阅状态、收到消息和发布结果。 -->
                <Border Grid.Column="0" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                            <TextBlock Text="MQTT 收发记录"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Background="#FEF3C7"
                                    BorderBrush="#FCD34D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,5">
                                <TextBlock x:Name="MqttConnectionTextBlock"
                                           Foreground="#B45309"
                                           FontWeight="SemiBold"
                                           Text="状态：未连接" />
                            </Border>
                        </DockPanel>

                        <TextBox x:Name="MqttLogTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Grid>
                </Border>

                <!-- MQTT 发布区：填写主题、QoS、Retain 和消息体后直接发布到 broker。 -->
                <Border Grid.Column="2" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.7*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Margin="0,0,0,10"
                                   LastChildFill="False">
                            <TextBlock Text="发布消息"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Button x:Name="MqttSampleButton"
                                    DockPanel.Dock="Right"
                                    MinWidth="96"
                                    Content="载入示例"
                                    Click="MqttSampleButton_Click" />
                        </DockPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Text="发布主题" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="MqttPublishTopicTextBox" Text="gkg/demo/outbox" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                            <TextBlock Text="发布 QoS" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="MqttPublishQoSComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="QoS 0" Tag="0" />
                                <ComboBoxItem Content="QoS 1" Tag="1" />
                                <ComboBoxItem Content="QoS 2" Tag="2" />
                            </ComboBox>
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                                <TextBlock Text="消息内容"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <CheckBox x:Name="MqttRetainCheckBox"
                                          DockPanel.Dock="Right"
                                          VerticalAlignment="Center"
                                          Content="Retain" />
                            </DockPanel>

                            <TextBox x:Name="MqttMessageTextBox"
                                     Grid.Row="1"
                                     MinHeight="260"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Style="{StaticResource ConsoleTextBoxStyle}"
                                     KeyDown="MqttMessageTextBox_KeyDown" />
                        </Grid>

                        <Button x:Name="MqttPublishButton"
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,12,0,0"
                                MinWidth="110"
                                HorizontalAlignment="Center"
                                Content="发布"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="MqttPublishButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- STOMP 页面：上方连接和订阅参数，下方左右布局，左侧日志、右侧发送。 -->
        <Grid x:Name="StompView"
              Grid.Row="1"
              Margin="18"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- STOMP 参数区：配置 tcp/ssl、broker、ClientId、账号密码和订阅方式。 -->
            <Border Grid.Row="0" Style="{StaticResource ToolPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="0.6*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="协议" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="StompSchemeComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="TCP" Tag="tcp" />
                                <ComboBoxItem Content="SSL" Tag="ssl" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Broker 地址" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompBrokerHostTextBox" Text="127.0.0.1" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="端口" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompBrokerPortTextBox" Text="61613" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Text="ClientId" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompClientIdTextBox" Text="ProtocolTestBench.StompClient" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,12,0">
                            <TextBlock Text="Host / VHost" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompHostHeaderTextBox"
                                     Text="/"
                                     ToolTip="RabbitMQ 这里通常填虚拟主机，例如 /；不是 broker 的 IP 或域名。留空则不主动发送 host 头。" />
                        </StackPanel>

                        <StackPanel Grid.Column="5" Margin="0,0,12,0">
                            <TextBlock Text="用户名" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompUserNameTextBox" Text="guest"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6" Margin="0,0,12,0">
                            <TextBlock Text="密码" Style="{StaticResource FieldLabelStyle}" />
                            <PasswordBox x:Name="StompPasswordBox" Password="guest"/>
                        </StackPanel>

                        <StackPanel Grid.Column="7"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button x:Name="StompConnectButton"
                                    Content="连接"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="StompConnectButton_Click" />
                            <Button x:Name="StompClearButton"
                                    Content="清空日志"
                                    Margin="10,0,0,0"
                                    Click="StompClearLogButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="订阅类型" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="StompSubscribeTypeComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Queue" Tag="Queue" />
                                <ComboBoxItem Content="Topic" Tag="Topic" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="订阅目标" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompSubscribeDestinationTextBox" Text="demo.queue" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Ack 模式" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="StompAckModeComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Auto" Tag="AutoAcknowledge" />
                                <ComboBoxItem Content="Client" Tag="ClientAcknowledge" />
                                <ComboBoxItem Content="Individual" Tag="IndividualAcknowledge" />
                            </ComboBox>
                        </StackPanel>

                        <Button x:Name="StompSubscribeButton"
                                Grid.Column="3"
                                MinWidth="86"
                                Margin="0,22,10,0"
                                Content="订阅"
                                Click="StompSubscribeButton_Click" />

                        <Button x:Name="StompUnsubscribeButton"
                                Grid.Column="4"
                                MinWidth="86"
                                Margin="0,22,0,0"
                                Content="取消订阅"
                                Click="StompUnsubscribeButton_Click" />

                        <Border Grid.Column="6"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,9"
                                VerticalAlignment="Bottom">
                            <TextBlock x:Name="StompStatusTextBlock"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="未连接：填写 broker、ClientId 和目标地址后连接" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" MinWidth="410" />
                </Grid.ColumnDefinitions>

                <!-- STOMP 日志区：显示连接状态、订阅状态、收到消息和异常。 -->
                <Border Grid.Column="0" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                            <TextBlock Text="STOMP 收发记录"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Background="#E0F2FE"
                                    BorderBrush="#7DD3FC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,5">
                                <TextBlock x:Name="StompConnectionTextBlock"
                                           Foreground="#0369A1"
                                           FontWeight="SemiBold"
                                           Text="状态：未连接" />
                            </Border>
                        </DockPanel>

                        <TextBox x:Name="StompLogTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource ConsoleTextBoxStyle}" />
                    </Grid>
                </Border>

                <!-- STOMP 发送区：选择 Queue / Topic 目标后发送文本或 JSON 消息体。 -->
                <Border Grid.Column="2" Style="{StaticResource ToolPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.4*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Margin="0,0,0,10"
                                   LastChildFill="False">
                            <TextBlock Text="发送消息"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <Button x:Name="StompSampleButton"
                                    DockPanel.Dock="Right"
                                    MinWidth="96"
                                    Content="载入示例"
                                    Click="StompSampleButton_Click" />
                        </DockPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Text="发送类型" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="StompPublishTypeComboBox"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Queue" Tag="Queue" />
                                <ComboBoxItem Content="Topic" Tag="Topic" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                            <TextBlock Text="发送目标" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="StompPublishDestinationTextBox" Text="demo.queue" />
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="消息内容"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <TextBox x:Name="StompMessageTextBox"
                                     Grid.Row="1"
                                     MinHeight="260"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Style="{StaticResource ConsoleTextBoxStyle}"
                                     KeyDown="StompMessageTextBox_KeyDown" />
                        </Grid>

                        <Button x:Name="StompSendButton"
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,12,0,0"
                                MinWidth="110"
                                HorizontalAlignment="Center"
                                Content="发送"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="StompSendButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
