<Window x:Class="ProtocolTestBench.JsonFormatterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON 美化"
        Height="640"
        Width="820"
        MinHeight="480"
        MinWidth="640"
        FontFamily="Microsoft YaHei UI"
        Background="#EEF3F8"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ToolPanelStyle}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="JSON 编辑器"
                               Style="{StaticResource PanelTitleStyle}" />
                    <TextBlock Text="输入时实时校验；点击美化会格式化为缩进 JSON。"
                               Style="{StaticResource HintTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="JsonStatusTextBlock"
                               Text="请输入 JSON"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14"
                Style="{StaticResource ToolPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="JSON 内容"
                           Style="{StaticResource FieldLabelStyle}" />
                <RichTextBox x:Name="JsonEditorTextBox"
                             Grid.Row="1"
                             AcceptsTab="True"
                             Background="{StaticResource ConsoleBrush}"
                             Foreground="#DDE7F3"
                             BorderBrush="#1E293B"
                             BorderThickness="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             PreviewTextInput="JsonEditorTextBox_PreviewTextInput"
                             PreviewKeyDown="JsonEditorTextBox_PreviewKeyDown"
                             TextChanged="JsonEditorTextBox_TextChanged" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <TextBlock x:Name="JsonDetailTextBlock"
                       DockPanel.Dock="Left"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="支持对象或数组 JSON。" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="FormatJsonButton"
                        MinWidth="108"
                        Content="一键美化"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="FormatJsonButton_Click" />
                <Button MinWidth="88"
                        Margin="10,0,0,0"
                        Content="关闭"
                        Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
