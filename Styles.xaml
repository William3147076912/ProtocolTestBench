<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 全局颜色资源：界面统一从这里取色，后续换主题时优先改这一段。 -->
    <SolidColorBrush x:Key="TextBrush" Color="#17202C" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F7FAFC" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E1EC" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#047857" />
    <SolidColorBrush x:Key="ConsoleBrush" Color="#0F172A" />

    <!-- 普通文本默认样式，保证所有 TextBlock 的颜色和垂直对齐一致。 -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- 表单字段标签样式，用在“端口”“Broker URI”这类输入项标题上。 -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- 面板标题样式，用在日志区和发送区标题上。 -->
    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- 次要说明文字样式，用在窗口副标题等低优先级信息。 -->
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- 普通输入框样式：所有参数输入控件共享，保持高度、边框和内边距一致。 -->
    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectionBrush" Value="#93C5FD" />
    </Style>

    <!-- 控制台输入/输出样式：用于日志和 CFX JSON，深色背景更适合长文本调试。 -->
    <Style x:Key="ConsoleTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="{StaticResource ConsoleBrush}" />
        <Setter Property="Foreground" Value="#DDE7F3" />
        <Setter Property="BorderBrush" Value="#1E293B" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="CaretBrush" Value="White" />
    </Style>

    <!-- ComboBox、Button、ToggleButton 统一控件尺寸，避免操作区控件高低不齐。 -->
    <Style TargetType="ComboBox">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <!-- 主操作按钮样式，用在启动、打开、发送等高频关键动作。 -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <!--
            WPF 默认 Button 模板会受系统主题影响，有些状态下不完全按 Foreground 渲染文字。
            这里不用 ContentPresenter，而是显式 TextBlock 绑定 Foreground，避免被全局 TextBlock 样式覆盖。
        -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#CBD5E1" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#94A3B8" />
                            <Setter Property="Foreground" Value="#F8FAFC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToggleButton">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- 顶部菜单样式。MenuItem 仍用 WPF 原生菜单行为，只调整间距和文字权重。 -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <!-- 通用工具面板样式：参数区、日志区、发送区都使用这一套边框和留白。 -->
    <Style x:Key="ToolPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- 状态胶囊样式，用于展示轻量级运行状态。 -->
    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="#ECFDF5" />
        <Setter Property="BorderBrush" Value="#A7F3D0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
</ResourceDictionary>
